# -----------------------------------------------------------------------------
# SHRAM SAATHI - ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------

# --- BACKEND VARIABLES ---

# Backend server port
PORT=5000

# Sarvam AI API Key (from app.sarvam.ai)
# Required for Text-to-Speech (TTS) and Speech-to-Text (STT) services
SARVAM_API_KEY=

# Google AI Studio API Key (from aistudio.google.com)
# Required for Gemini 1.5 Flash LLM and text-embedding-004
GEMINI_API_KEY=

# Supabase Project settings (from supabase.com)
# Required for vector database (pgvector) to store and retrieve scheme chunks
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Geolocation preference (from user choice)
# Options: "ON_LOAD" or "ON_WEATHER_QUERY"
GEO_PREFERENCE=

# URL of the deployed frontend (for CORS)
FRONTEND_URL=http://localhost:5173


# --- FRONTEND VARIABLES ---

# Note: Frontend variables should typically start with VITE_ and be in an .env file
# inside the frontend folder, or configured in the Vercel dashboard.

# Backend API URL
VITE_API_URL=http://localhost:5000
